<prefigure xmlns="https://prefigure.org" label="solution-logistic-curves">
  <diagram dimensions="(300,300)" margins="25">

<definition>f1(t) = 2 / (1 + 1 * exp(-2*t))</definition>
<definition>f2(t) = 2 / (1 + 2 * exp(-2*t))</definition>
<definition>f3(t) = 2 / (1 + 3 * exp(-2*t))</definition>
<definition>f4(t) = 2 / (1 + 4 * exp(-2*t))</definition>
<definition>f5(t) = 2 / (1 + 5 * exp(-2*t))</definition>
  <coordinates bbox="(-3,-3,3,3)">
    <grid-axes xlabel="t" ylabel="y(t)"/>

    <graph function="f1" stroke="blue" />
    <graph function="f2" stroke="red" />
    <graph function="f3" stroke="green" />
    <graph function="f4" stroke="orange" />
    <graph function="f5" stroke="purple" />    


  </coordinates>


  </diagram>
</prefigure>