<prefigure xmlns="https://prefigure.org" label="solution-second-order-curves">
  <diagram dimensions="(300,300)" margins="25">

<definition>f1(t) = cos(3*t) + 1*sin(3*t)</definition>
<definition>f2(t) = cos(3*t) + 2*sin(3*t)</definition>
<definition>f3(t) = cos(3*t) + 3*sin(3*t)</definition>
<definition>f4(t) = cos(3*t) + 4*sin(3*t)</definition>
<definition>f5(t) = cos(3*t) + 5*sin(3*t)</definition>
  <coordinates bbox="(-3,-5.5,3,5.5)">
    <grid-axes xlabel="t" ylabel="y(t)"/>

    <graph function="f1" stroke="blue" />
    <graph function="f2" stroke="red" />
    <graph function="f3" stroke="green" />
    <graph function="f4" stroke="orange" />
    <graph function="f5" stroke="purple" />    


  </coordinates>


  </diagram>
</prefigure>