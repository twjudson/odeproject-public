<prefigure xmlns="https://prefigure.org" label="slope-field-x-times-t">
<diagram dimensions="(300,300)" margins="30">
<definition>f(t,x) = x*t</definition>
<coordinates bbox="[-2.5,-2.5,2.5,2.5]">
    <grid-axes xlabel="t" ylabel="x"/>
    <definition>gap = 1</definition>
    <slope-field function="f" arrows="yes" thickness="2" stroke="blue" spacings="((-2,gap,2),(-2,gap,2))"/>
</coordinates>
</diagram>
</prefigure>